        "eBay",
        "Bing",
        "Perplexity",
        "Wikipedia (en)"
      ],
      "Add": [
        {
          "Name": "Brave",
          "Description": "Brave Search",
          "Alias": "br",
          "Method": "GET",
          "URLTemplate": "https://search.brave.com/search?q={searchTerms}",
          "IconURL": "data:image/x-icon;base64,"
        }
      ]
    },
